  "types": [
    {
      "name": "EscrowAccount",
      "docs": [
        "Per-duel escrow account. Seeds: [\"escrow\", duel_id]."
      ],
      "type": {
        "kind": "struct",
        "fields": [
          {
            "name": "duel_id",
            "docs": [
