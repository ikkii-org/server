            ],
            "type": "pubkey"
          },
          {
            "name": "fee_bps",
            "docs": [
              "Platform fee in basis points (e.g. 250 = 2.5%)"
            ],
            "type": "u16"
          },
          {
            "name": "treasury",
            "docs": [
              "Treasury wallet that receives platform fees"
            ],
            "type": "pubkey"
          },
          {
            "name": "bump",
            "docs": [
              "PDA bump"
            ],
            "type": "u8"
          }
