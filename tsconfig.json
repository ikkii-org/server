{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "bun-types"
    ],
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "ikki-escrow/*": [
        "../escrow/*"
      ]
    },
    "resolveJsonModule": true
  },
  "include": [
    "src/**/*",
    "../escrow/target/types/**/*.ts",
    "../escrow/sdk/src/**/*.ts"
  ]
}